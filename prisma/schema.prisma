generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  email    String   @unique
  fullname String?
  role     UserRole @default(USER)

  cart Cart?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id String @id @default(cuid())

  name String

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id String @id @default(cuid())

  name     String @unique
  imageUrl String
  price    Int
  weight   Int

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  ingredients Ingredient[]

  nutrition Nutrition?

  cartItems CartItem[]

  // Поле для продуктов, которые ВХОДЯТ в этот сет (если этот продукт — сет)
  setItems Product[] @relation("SetToProducts")

  // ОБЯЗАТЕЛЬНОЕ ОБРАТНОЕ ПОЛЕ: Сеты, в которых СОДЕРЖИТСЯ этот продукт
  containedIn Product[] @relation("SetToProducts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Nutrition {
  id String @id @default(cuid())

  calories Float
  proteins Float
  fats     Float
  carbs    Float

  product   Product @relation(fields: [productId], references: [id])
  productId String  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ingredient {
  id String @id @default(cuid())

  name String

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id String @id @default(cuid())

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id String @id @default(cuid())

  cart   Cart   @relation(fields: [cartId], references: [id])
  cartId String

  productItem Product @relation(fields: [productId], references: [id])
  productId   String

  quantity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
}
